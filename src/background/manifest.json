{
  "manifest_version": 3,
  "name": "Simple Outliner / 智慧網頁大綱",
  "version": "0.8.0",
  "description": "Simple Outliner / 自動生成網頁大綱、目錄，支援 Inoreader 與 Feedly。",
  "options_page": "options.html",
  "action": {
    "default_icon": "icon.png",
    "default_title": "Simple Outliner / 智慧網頁大綱"
  },
  "icons": {
    "16": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "toc.js"
      ],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self';object-src 'self';script-src-elem 'self' 'unsafe-inline';"
  },
  "commands": {
    "toggle": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E",
        "chromeos": "Ctrl+Shift+E",
        "linux": "Ctrl+Shift+E"
      },
      "description": "載入/卸載 目錄"
    },
    "prev": {
      "description": "跳至上一個標題"
    },
    "next": {
      "description": "跳至下一個標題"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "author": "louchenabc@gmail.com"
}
